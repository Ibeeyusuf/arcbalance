# Arc Testnet (Canteen-hosted node)
# Get this by running: arc-canteen rpc-url
ARC_RPC_URL=https://rpc.testnet.arc-node.thecanteenapp.com/v1/YOUR_KEY_HERE

# OpenRouter — get free key from https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Testnet-only throwaway wallet private key
AGENT_PRIVATE_KEY=0x...

# Public vars
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_EXPLORER=https://testnet.arcscan.app
